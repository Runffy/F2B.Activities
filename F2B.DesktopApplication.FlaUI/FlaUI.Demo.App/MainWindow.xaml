<Window x:Class="FlaUI.Demo.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FlaUI Demo App"
        Width="520"
        Height="640"
        WindowStartupLocation="CenterScreen"
        AutomationProperties.AutomationId="demoMainWindow"
        AutomationProperties.Name="FlaUI Demo App">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   x:Name="lblStatus"
                   AutomationProperties.AutomationId="lblStatus"
                   AutomationProperties.Name="Status"
                   Text="Ready"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="btnClick"
                    AutomationProperties.AutomationId="btnClick"
                    Content="Click Me"
                    Width="120"
                    Height="32"
                    Margin="0,0,8,0"
                    Click="BtnClick_OnClick" />
            <Button x:Name="btnDoubleClick"
                    AutomationProperties.AutomationId="btnDoubleClick"
                    Content="Double Click Me"
                    Width="140"
                    Height="32"
                    Margin="0,0,8,0"
                    MouseDoubleClick="BtnDoubleClick_OnMouseDoubleClick" />
            <Button x:Name="btnDisabled"
                    AutomationProperties.AutomationId="btnDisabled"
                    Content="Disabled Button"
                    Width="130"
                    Height="32"
                    IsEnabled="False" />
        </StackPanel>

        <CheckBox Grid.Row="2"
                  x:Name="chkAgree"
                  AutomationProperties.AutomationId="chkAgree"
                  Content="I agree to the terms"
                  Margin="0,0,0,8"
                  Checked="ChkAgree_OnChanged"
                  Unchecked="ChkAgree_OnChanged" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Name:" VerticalAlignment="Center" Width="50" />
            <TextBox x:Name="txtName"
                     AutomationProperties.AutomationId="txtName"
                     AutomationProperties.Name="Name"
                     Width="300"
                     Height="26"
                     Text="OpenRPA" />
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="City:" VerticalAlignment="Center" Width="50" />
            <ComboBox x:Name="cboCity"
                      AutomationProperties.AutomationId="cboCity"
                      AutomationProperties.Name="City"
                      Width="200"
                      SelectedIndex="0">
                <ComboBoxItem Content="Beijing" />
                <ComboBoxItem Content="Shanghai" />
                <ComboBoxItem Content="Guangzhou" />
            </ComboBox>
        </StackPanel>

        <TextBlock Grid.Row="5"
                   Text="Scroll area (Scroll Into View test)"
                   FontWeight="SemiBold"
                   Margin="0,8,0,4" />

        <ScrollViewer Grid.Row="6"
                      x:Name="scrollMain"
                      AutomationProperties.AutomationId="scrollMain"
                      VerticalScrollBarVisibility="Auto"
                      BorderBrush="#CCCCCC"
                      BorderThickness="1"
                      Padding="8">
            <StackPanel x:Name="panelScrollContent"
                        AutomationProperties.AutomationId="panelScrollContent"
                        MinHeight="520">
                <TextBlock Text="Top of scroll area" Margin="0,0,0,8" />
                <TextBlock Text="Line 1" Margin="0,0,0,4" />
                <TextBlock Text="Line 2" Margin="0,0,0,4" />
                <TextBlock Text="Line 3" Margin="0,0,0,4" />
                <TextBlock Text="Line 4" Margin="0,0,0,4" />
                <TextBlock Text="Line 5" Margin="0,0,0,4" />
                <TextBlock Text="Line 6" Margin="0,0,0,4" />
                <TextBlock Text="Line 7" Margin="0,0,0,4" />
                <TextBlock Text="Line 8" Margin="0,0,0,4" />
                <TextBlock Text="Line 9" Margin="0,0,0,4" />
                <TextBlock Text="Line 10" Margin="0,0,0,4" />
                <TextBlock Text="Line 11" Margin="0,0,0,4" />
                <TextBlock Text="Line 12" Margin="0,0,0,4" />
                <Button x:Name="btnScrollTarget"
                        AutomationProperties.AutomationId="btnScrollTarget"
                        Content="Scroll Target Button"
                        Width="180"
                        Height="32"
                        Margin="0,16,0,0"
                        Click="BtnScrollTarget_OnClick" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="btnReset"
                    AutomationProperties.AutomationId="btnReset"
                    Content="Reset"
                    Width="90"
                    Height="28"
                    Margin="0,0,8,0"
                    Click="BtnReset_OnClick" />
            <Button x:Name="btnClose"
                    AutomationProperties.AutomationId="btnClose"
                    Content="Close App"
                    Width="90"
                    Height="28"
                    Click="BtnClose_OnClick" />
        </StackPanel>
    </Grid>
</Window>
