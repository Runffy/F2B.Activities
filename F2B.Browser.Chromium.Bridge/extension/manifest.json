{
  "manifest_version": 3,
  "name": "F2B Chromium Bridge",
  "version": "2.5.26",
  "description": "Connects Chromium to the local F2B Bridge host application.",
  "permissions": [
    "scripting",
    "tabs",
    "storage",
    "alarms",
    "cookies",
    "downloads",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content/dom-selector.js",
        "content/bridge-executor.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
