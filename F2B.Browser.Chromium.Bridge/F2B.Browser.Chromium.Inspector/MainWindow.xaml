<Window x:Class="F2B.Browser.Chromium.Inspector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:F2B.Browser.Chromium.Inspector.Models"
        Title="F2B Chromium Inspector" Height="720" Width="960" MinHeight="520" MinWidth="720"
        Background="#FFF0F0F0">
    <Window.Resources>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Background" Value="#FFE8E8E8" />
            <Setter Property="BorderBrush" Value="#FFBDBDBD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#FFBDBDBD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>

        <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#FF333333" />
        </Style>

        <Style x:Key="ValidateButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{Binding ValidateButtonBackground}" />
            <Setter Property="BorderBrush" Value="{Binding ValidateButtonBorderBrush}" />
            <Setter Property="Foreground" Value="{Binding ValidateButtonForeground}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#FFE8E8E8" BorderBrush="#FFBDBDBD" BorderThickness="0,0,0,1" Padding="6,4">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Content="Validate" Style="{StaticResource ValidateButtonStyle}"
                            Command="{Binding ValidateCommand}" ToolTip="Validate selector (waits up to 5s for element to appear)" />
                    <Button Content="Indicate Element" Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding IndicateCommand}"
                            ToolTip="Pick an element in the active Chrome tab. Press F2 to pause for 3 seconds (hover menus). Press Esc to cancel." />
                    <Button Content="Highlight" Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding HighlightCommand}" ToolTip="Highlight matched element (waits up to 5s for element to appear)" />
                    <Button Content="Refresh Connection" Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding RefreshConnectionCommand}" ToolTip="Refresh bridge connection status" />
                </StackPanel>
                <TextBlock Text="{Binding ConnectionStatus}" VerticalAlignment="Center" Margin="12,0,0,0"
                           Foreground="#FF555555" TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#FFE8E8E8" BorderBrush="#FFBDBDBD" BorderThickness="0,1,0,0" Padding="8,3">
            <DockPanel LastChildFill="True">
                <TextBlock Text="Target Element:" Foreground="#FF555555" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBlock Text="{Binding TargetElementDisplay}" VerticalAlignment="Center" FontWeight="SemiBold"
                           Foreground="{Binding TargetElementForeground}" TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>

        <Grid Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="180" />
                <RowDefinition Height="4" />
                <RowDefinition Height="*" MinHeight="180" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="240" />
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="280" MinWidth="200" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                    <DockPanel LastChildFill="True">
                        <Border DockPanel.Dock="Top" Background="#FFE0E0E0" BorderBrush="#FFBDBDBD"
                                BorderThickness="0,0,0,1" Padding="8,5">
                            <TextBlock Text="Selector Editor" Style="{StaticResource PanelTitleStyle}" />
                        </Border>
                        <ListBox ItemsSource="{Binding SelectorLevels}"
                                 SelectedItem="{Binding SelectedSelectorLevel, Mode=TwoWay}"
                                 BorderThickness="0"
                                 ScrollViewer.CanContentScroll="False"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.PanningMode="Both"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.ScrollUnit="Pixel">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="2,1" />
                                    <Setter Property="MaxHeight" Value="28" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:InspectorSelectorLevel}">
                                    <DockPanel LastChildFill="True">
                                        <CheckBox DockPanel.Dock="Left"
                                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                  IsEnabled="{Binding CanDisable}"
                                                  VerticalAlignment="Center" Margin="2,0,6,0" />
                                        <TextBlock Text="{Binding TagLine}"
                                                   VerticalAlignment="Center"
                                                   FontFamily="Consolas" FontSize="12"
                                                   TextWrapping="NoWrap" />
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#FFD0D0D0" />

                <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                    <DockPanel LastChildFill="True">
                        <Border DockPanel.Dock="Top" Background="#FFE0E0E0" BorderBrush="#FFBDBDBD"
                                BorderThickness="0,0,0,1" Padding="8,5">
                            <TextBlock Text="Selected Items" Style="{StaticResource PanelTitleStyle}" />
                        </Border>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding SelectedItemProperties}" Margin="4,2">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:InspectorPropertyItem}">
                                        <DockPanel Margin="2,1">
                                            <CheckBox DockPanel.Dock="Right"
                                                      IsChecked="{Binding IsRegex, Mode=TwoWay}"
                                                      IsEnabled="{Binding SupportsRegex}"
                                                      Content="re"
                                                      ToolTip="Use regular expression (name-re, title-re, ...)"
                                                      VerticalAlignment="Center"
                                                      Margin="6,0,0,0"
                                                      FontSize="11"
                                                      FontFamily="Consolas" />
                                            <CheckBox DockPanel.Dock="Left"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      IsEnabled="{Binding CanToggle}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,6,0" />
                                            <TextBlock VerticalAlignment="Center"
                                                       FontSize="12"
                                                       FontFamily="Consolas"
                                                       TextWrapping="NoWrap"
                                                       Text="{Binding DisplayText, Mode=OneWay}" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

            <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Background="#FFD0D0D0" />

            <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top" Background="#FFE0E0E0" BorderBrush="#FFBDBDBD"
                            BorderThickness="0,0,0,1" Padding="8,5">
                        <TextBlock Text="Selector" Style="{StaticResource PanelTitleStyle}" />
                    </Border>
                    <TextBox Text="{Binding SelectorXml, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="NoWrap" AcceptsReturn="True"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="12"
                             Background="White" BorderThickness="0" Padding="4" />
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
