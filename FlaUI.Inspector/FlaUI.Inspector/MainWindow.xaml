<Window x:Class="FlaUI.Inspector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:FlaUI.Inspector.Models"
        Title="FlaUI Inspector" Height="780" Width="1200" MinHeight="600" MinWidth="960"
        Background="#FFF0F0F0">
    <Window.Resources>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Background" Value="#FFE8E8E8" />
            <Setter Property="BorderBrush" Value="#FFBDBDBD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#FFBDBDBD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>

        <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#FF333333" />
        </Style>

        <Style x:Key="ValidateButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{Binding ValidateButtonBackground}" />
            <Setter Property="BorderBrush" Value="{Binding ValidateButtonBorderBrush}" />
            <Setter Property="Foreground" Value="{Binding ValidateButtonForeground}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="#FFE8E8E8" BorderBrush="#FFBDBDBD" BorderThickness="0,0,0,1" Padding="6,4">
            <StackPanel Orientation="Horizontal">
                <Button Content="Validate" Style="{StaticResource ValidateButtonStyle}"
                        Command="{Binding ValidateCommand}" ToolTip="Validate selector" />
                <Button Content="Indicate Element" Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding IndicateCommand}"
                        ToolTip="Select a UI element from the screen. Press F2 during indicate to pause for 3 seconds (for hover menus)." />
                <Button Content="Highlight" Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding HighlightCommand}" ToolTip="Highlight the element matched by selector" />
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#FFE8E8E8" BorderBrush="#FFBDBDBD" BorderThickness="0,1,0,0" Padding="8,3">
            <DockPanel LastChildFill="True">
                <TextBlock Text="Target Element:" Foreground="#FF555555" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBlock Text="{Binding TargetElementDisplay}" VerticalAlignment="Center" FontWeight="SemiBold" />
            </DockPanel>
        </Border>

        <!-- Main layout -->
        <Grid Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="180" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" MinWidth="400" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: Visual Tree + Property Explorer -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="120" />
                    <RowDefinition Height="4" />
                    <RowDefinition Height="*" MinHeight="120" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}">
                    <DockPanel LastChildFill="True">
                        <Border DockPanel.Dock="Top" Background="#FFE0E0E0" BorderBrush="#FFBDBDBD"
                                BorderThickness="0,0,0,1" Padding="8,5">
                            <TextBlock Text="Visual Tree" Style="{StaticResource PanelTitleStyle}" />
                        </Border>
                        <TreeView ItemsSource="{Binding VisualTree}" BorderThickness="0"
                                  SelectedItemChanged="VisualTree_OnSelectedItemChanged"
                                  Margin="2">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.Resources>
                                <HierarchicalDataTemplate DataType="{x:Type models:VisualTreeNode}" ItemsSource="{Binding Children}">
                                    <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Background="#FFD0D0D0" />

                <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}">
                    <DockPanel LastChildFill="True">
                        <Border DockPanel.Dock="Top" Background="#FFE0E0E0" BorderBrush="#FFBDBDBD"
                                BorderThickness="0,0,0,1" Padding="8,5">
                            <TextBlock Text="Property Explorer" Style="{StaticResource PanelTitleStyle}" />
                        </Border>
                        <ListView ItemsSource="{Binding PropertyExplorerItems}" BorderThickness="0">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Property" DisplayMemberBinding="{Binding Name}" Width="110" />
                                    <GridViewColumn Header="Value" DisplayMemberBinding="{Binding Value}" Width="130" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </DockPanel>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#FFD0D0D0" />

            <!-- RIGHT AREA: top = Selector Editor + Selected Items, bottom = Selector (full width) -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="160" />
                    <RowDefinition Height="4" />
                    <RowDefinition Height="*" MinHeight="160" />
                </Grid.RowDefinitions>

                <!-- Top row: Selector Editor | Selected Items -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="200" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="260" MinWidth="180" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                        <DockPanel LastChildFill="True">
                            <Border DockPanel.Dock="Top" Background="#FFE0E0E0" BorderBrush="#FFBDBDBD"
                                    BorderThickness="0,0,0,1" Padding="8,5">
                                <TextBlock Text="Selector Editor" Style="{StaticResource PanelTitleStyle}" />
                            </Border>
                            <ListBox ItemsSource="{Binding SelectorLevels}"
                                     SelectedItem="{Binding SelectedSelectorLevel, Mode=TwoWay}"
                                     BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="2,1" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:SelectorLevel}">
                                        <DockPanel LastChildFill="True">
                                            <CheckBox DockPanel.Dock="Left"
                                                      IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                      IsEnabled="{Binding CanDisable}"
                                                      VerticalAlignment="Center" Margin="2,0,6,0" />
                                            <TextBlock Text="{Binding TagLine}"
                                                       VerticalAlignment="Center"
                                                       FontFamily="Consolas" FontSize="12"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#FFD0D0D0" />

                    <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                        <DockPanel LastChildFill="True">
                            <Border DockPanel.Dock="Top" Background="#FFE0E0E0" BorderBrush="#FFBDBDBD"
                                    BorderThickness="0,0,0,1" Padding="8,5">
                                <TextBlock Text="Selected Items" Style="{StaticResource PanelTitleStyle}" />
                            </Border>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding SelectedItemProperties}" Margin="4,2">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:ElementPropertyItem}">
                                            <DockPanel Margin="2,1">
                                                <CheckBox DockPanel.Dock="Right"
                                                          IsChecked="{Binding IsRegex, Mode=TwoWay}"
                                                          IsEnabled="{Binding SupportsRegex}"
                                                          Content="re"
                                                          ToolTip="Use regular expression (name-re, cls-re, ...)"
                                                          VerticalAlignment="Center"
                                                          Margin="6,0,0,0"
                                                          FontSize="11"
                                                          FontFamily="Consolas" />
                                                <CheckBox DockPanel.Dock="Left"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          IsEnabled="{Binding CanToggle}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,6,0" />
                                                <TextBlock VerticalAlignment="Center"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding DisplayText, Mode=OneWay}" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>

                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Background="#FFD0D0D0" />

                <!-- Bottom row: Selector spans full width -->
                <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}">
                    <DockPanel LastChildFill="True">
                        <Border DockPanel.Dock="Top" Background="#FFE0E0E0" BorderBrush="#FFBDBDBD"
                                BorderThickness="0,0,0,1" Padding="8,5">
                            <TextBlock Text="Selector" Style="{StaticResource PanelTitleStyle}" />
                        </Border>
                        <TextBox Text="{Binding SelectorXml, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12"
                                 Background="White" BorderThickness="0" Padding="4" />
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
