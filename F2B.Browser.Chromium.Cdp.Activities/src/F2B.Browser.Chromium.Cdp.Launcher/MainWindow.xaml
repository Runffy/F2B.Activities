<Window x:Class="F2B.Browser.Chromium.Cdp.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CDP Browser Launcher"
        Height="520"
        Width="720"
        MinHeight="420"
        MinWidth="640"
        WindowStartupLocation="CenterScreen"
        Icon="CdpBrowserLauncher.ico">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="170" />
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="Auto" />
    </Grid.ColumnDefinitions>

    <!-- Row 0: Browser Type + Port -->
    <TextBlock Grid.Row="0" Grid.Column="0" Text="Browser Type:" VerticalAlignment="Center" Margin="0,0,8,10" />
    <Grid Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="100" />
      </Grid.ColumnDefinitions>
      <ComboBox x:Name="BrowserTypeCombo"
                Grid.Column="0"
                Height="28"
                SelectedIndex="0"
                SelectionChanged="BrowserTypeCombo_OnSelectionChanged">
        <ComboBoxItem Content="Chrome" />
        <ComboBoxItem Content="MsEdge" />
      </ComboBox>
      <TextBlock Grid.Column="1" Text="Port:" VerticalAlignment="Center" Margin="16,0,8,0" />
      <TextBox x:Name="PortTextBox"
               Grid.Column="2"
               Height="28"
               VerticalContentAlignment="Center"
               TextChanged="ConfigField_OnChanged" />
    </Grid>

    <!-- Row 1: Executable Path -->
    <TextBlock Grid.Row="1" Grid.Column="0" Text="Browser Executable Path:" VerticalAlignment="Center" Margin="0,0,8,10" TextWrapping="Wrap" />
    <TextBox x:Name="ExecutablePathTextBox"
             Grid.Row="1"
             Grid.Column="1"
             Height="28"
             Margin="0,0,8,10"
             VerticalContentAlignment="Center"
             TextChanged="ConfigField_OnChanged" />
    <Button Grid.Row="1"
            Grid.Column="2"
            Content="Browse"
            Width="88"
            Height="28"
            Margin="0,0,0,10"
            Click="BrowseExecutable_OnClick" />

    <!-- Row 2: User Data Dir Root -->
    <TextBlock Grid.Row="2" Grid.Column="0" Text="Browser Data Directory:" VerticalAlignment="Center" Margin="0,0,8,10" TextWrapping="Wrap" />
    <TextBox x:Name="UserDataDirRootTextBox"
             Grid.Row="2"
             Grid.Column="1"
             Height="28"
             Margin="0,0,8,10"
             VerticalContentAlignment="Center"
             TextChanged="ConfigField_OnChanged" />
    <Button Grid.Row="2"
            Grid.Column="2"
            Content="Browse"
            Width="88"
            Height="28"
            Margin="0,0,0,10"
            Click="BrowseUserDataRoot_OnClick" />

    <!-- Row 3: Effective path preview -->
    <TextBlock Grid.Row="3" Grid.Column="0" Text="Resolved user-data-dir:" VerticalAlignment="Top" Margin="0,0,8,12" TextWrapping="Wrap" />
    <TextBox x:Name="EffectivePathTextBox"
             Grid.Row="3"
             Grid.Column="1"
             Grid.ColumnSpan="2"
             Margin="0,0,0,12"
             IsReadOnly="True"
             TextWrapping="Wrap"
             MinHeight="28"
             VerticalContentAlignment="Center"
             Background="#FFF5F5F5"
             BorderThickness="1" />

    <!-- Row 4: History label + Run -->
    <TextBlock Grid.Row="4" Grid.Column="0" Text="History:" VerticalAlignment="Center" Margin="0,0,8,10" />
    <Button x:Name="RunButton"
            Grid.Row="4"
            Grid.Column="2"
            Content="Run"
            Width="88"
            Height="32"
            Margin="0,0,0,10"
            FontWeight="SemiBold"
            Click="Run_OnClick" />

    <!-- Row 5: hint -->
    <TextBlock Grid.Row="5"
               Grid.Column="0"
               Grid.ColumnSpan="3"
               Margin="0,0,0,6"
               Foreground="#FF555555"
               Text="Double-click a history item to restore settings. Run will open the browser, or attach if the same port and profile are already running."
               TextWrapping="Wrap" />

    <!-- Row 6: History list -->
    <ListBox x:Name="HistoryListBox"
             Grid.Row="6"
             Grid.Column="0"
             Grid.ColumnSpan="3"
             DisplayMemberPath="DisplayText"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             ScrollViewer.VerticalScrollBarVisibility="Auto"
             MouseDoubleClick="HistoryListBox_OnMouseDoubleClick" />
  </Grid>
</Window>
