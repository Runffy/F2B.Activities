<Window x:Class="SpiderAgent.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SpiderAgent" Height="820" Width="1420"
        MinHeight="640" MinWidth="1200">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Width" Value="112"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧：会话列表 -->
        <GroupBox Grid.Column="0" Header="工作会话" Padding="8" Margin="0,0,12,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Button Grid.Row="0"
                        Content="创建新会话"
                        Margin="0,0,0,8"
                        Command="{Binding CreateNewSessionCommand}"
                        ToolTip="{Binding CreateNewSessionTooltip}"/>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding WorkspaceSessions}"
                         SelectedItem="{Binding SelectedWorkspaceSession, Mode=TwoWay}"
                         ToolTip="选择历史会话以继续优化；录制或分析进行中时不可切换。">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2,6">
                                <TextBlock Text="{Binding DisplayTitle}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Subtitle}"
                                           FontSize="11"
                                           Foreground="#666"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </GroupBox>

        <!-- 右侧：原有工作区 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="SpiderAgent — 网络请求录制与分析"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding SelectedWorkspaceSession.DisplayTitle, StringFormat=当前会话：{0}, TargetNullValue=当前会话：（未选择）}"
                               FontSize="13"
                               Foreground="#555"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource ActionButton}"
                            Content="打开会话目录"
                            Margin="0,0,8,0"
                            Command="{Binding OpenSessionOutputDirectoryCommand}"
                            ToolTip="打开当前会话的输出目录（Output 日志、Python 脚本、分析报告）"/>
                    <Button Style="{StaticResource ActionButton}"
                            Content="删除当前会话"
                            Command="{Binding DeleteCurrentWorkspaceSessionCommand}"
                            ToolTip="永久删除当前选中的会话及本地文件（需二次确认）。录制或分析进行中时不可用。"/>
                </StackPanel>
            </Grid>

            <GroupBox Grid.Row="1" Header="录制设置" Padding="10" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="浏览器" VerticalAlignment="Center" Margin="0,0,12,8"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Chromium（Chrome 扩展）"
                               VerticalAlignment="Center" Margin="0,0,0,8" Foreground="#444"/>
                    <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
                        <Button Style="{StaticResource ActionButton}" Content="开始录制" Margin="0,0,8,8"
                                Command="{Binding StartRecordingCommand}"/>
                        <Button Style="{StaticResource ActionButton}" Content="停止录制" Margin="0,0,0,8"
                                Command="{Binding StopRecordingCommand}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Chrome 扩展 ID" VerticalAlignment="Center" Margin="0,0,12,8"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                             Text="{Binding ChromeExtensionId, Mode=OneWay}"
                             IsReadOnly="True"
                             Background="#F5F5F5"
                             Margin="0,0,0,8" Padding="6,4"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="扩展连接" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="{Binding BridgeStatusText}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding RecordingStatusText, StringFormat=状态: {0}}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding RecordedRequestCount, StringFormat=已捕获请求: {0}}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal">
                        <Button Style="{StaticResource ActionButton}" Content="打开扩展目录"
                                Command="{Binding OpenExtensionFolderCommand}"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Row="2" Header="分析 Prompt" Padding="10" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,8"
                                Visibility="{Binding IsSplitPromptMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="按步骤描述在录制过程中您做了什么操作"
                                   Margin="0,0,0,4"
                                   Foreground="#444"/>
                        <TextBox Text="{Binding RecordingStepsPrompt, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="56"
                                 VerticalScrollBarVisibility="Auto"
                                 Padding="8,6"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,0,0,8"
                                Visibility="{Binding IsSplitPromptMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="您期待爬虫脚本想要实现的目标是什么"
                                   Margin="0,0,0,4"
                                   Foreground="#444"/>
                        <TextBox Text="{Binding SpiderGoalPrompt, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="56"
                                 VerticalScrollBarVisibility="Auto"
                                 Padding="8,6"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.RowSpan="2" Margin="0,0,0,8"
                                Visibility="{Binding IsRefinementPromptMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="继续优化 / 修复要求（基于已有分析与脚本）"
                                   Margin="0,0,0,4"
                                   Foreground="#444"/>
                        <TextBox Text="{Binding UnifiedPrompt, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="120"
                                 VerticalScrollBarVisibility="Auto"
                                 Padding="8,6"
                                 ToolTip="首次分析完成后只需在此填写新的要求，无需再区分步骤与目标。"/>
                    </StackPanel>

                    <Grid Grid.Row="2" Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="自测最大次数：" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Width="60" Padding="4,2"
                                     Text="{Binding MaxSelfTestAttempts, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="每次点击「开始分析」（含后续继续优化）时独立使用此值。&#x0a;0 = 不限制重试次数，会一直尝试直到成功或用户手动停止。"/>
                            <TextBlock Text="(0=不限，每次分析独立计数)" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="#666"/>
                            <TextBlock Text="自测超时(秒)：" VerticalAlignment="Center" Margin="16,0,6,0"/>
                            <TextBox Width="60" Padding="4,2"
                                     Text="{Binding SelfTestTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="单次自测脚本最长运行时间。0 = 不限（批量下载推荐）。此前默认 120 秒会导致多集下载被误判失败。"/>
                            <TextBlock Text="(0=不限)" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="#666"/>
                            <CheckBox Content="测试时自动安装 requirements"
                                      IsChecked="{Binding AutoInstallRequirementsOnTest}"
                                      VerticalAlignment="Center"
                                      Margin="16,0,0,0"
                                      ToolTip="勾选后，每次自测前会使用下方指定的 Python 解释器执行 pip install -r requirements.txt。"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Style="{StaticResource ActionButton}"
                                Content="{Binding AnalyzeButtonText}"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                Command="{Binding AnalyzeOrStopCommand}"/>
                    </Grid>

                    <StackPanel Grid.Row="3"
                                Orientation="Horizontal"
                                Margin="0,6,0,0"
                                Visibility="{Binding AutoInstallRequirementsOnTest, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Python 解释器路径：" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Width="320" Padding="4,2"
                                 Text="{Binding PythonInterpreterPath, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="用于 pip install 与运行脚本。默认 python；若路径含空格无需手动加引号。"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <Grid Grid.Row="3" Margin="0,0,0,8">
                <TextBlock Text="Output" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button Style="{StaticResource ActionButton}" Content="清空 Output" HorizontalAlignment="Right"
                        Command="{Binding ClearOutputCommand}"/>
            </Grid>

            <Border Grid.Row="4"
                    BorderBrush="#CCCCCC"
                    BorderThickness="1"
                    CornerRadius="4">
                <TextBox Text="{Binding OutputText, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="13"
                         Padding="6,4"/>
            </Border>
        </Grid>
    </Grid>
</Window>
