{
  "manifest_version": 3,
  "name": "SpiderAgent Recorder",
  "version": "0.2.3",
  "description": "录制 Chrome 网络请求与 JS 资源，供 SpiderAgent 分析。",
  "key": "",
  "permissions": [
    "debugger",
    "tabs",
    "scripting",
    "activeTab",
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "SpiderAgent Recorder",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
